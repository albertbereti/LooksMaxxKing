# LOOKSMAXXKING Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control!

# Google Gemini API Key (get from https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# Stripe Keys (get from https://dashboard.stripe.com/apikeys)
# The secret key is ONLY for server-side scripts, NOT bundled in client
STRIPE_SECRET_KEY=sk_live_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
VITE_STRIPE_PUBLIC_KEY=pk_live_your_stripe_public_key_here

# Gmail credentials for Cloud Functions (Nodemailer)
GMAIL_EMAIL=your_email@gmail.com
GMAIL_PASSWORD=your_app_specific_password_here
